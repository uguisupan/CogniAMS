---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 各種コンテンツコレクションを取得
const devlogs = await getCollection('devlog');
const races = await getCollection('race');
const books = await getCollection('books');

// 公開日の新しい順にソート
const sortedDevlogs = devlogs.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const sortedRaces = races.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const sortedBooks = books.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 日付フォーマット (YYYY.MM.DD)
const formatDate = (date: Date) => {
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const d = String(date.getDate()).padStart(2, '0');
    return `${y}.${m}.${d}`;
};
---

<Layout title="開発ブログ ＆ 資料インデックス" theme="dark" hideNav={true}>
    <!-- 公式サイトへの誘導バナー -->
    <div style="background: rgba(214, 0, 98, 0.05); border: 2px solid var(--color-pink); padding: 20px; text-align: center; margin-bottom: 30px; box-shadow: 4px 4px 0px rgba(0, 0, 0, 0.15);">
        <h3 class="font-sans" style="color: var(--color-pink); font-weight: bold; font-size: 1.1rem; margin-bottom: 8px;">
            📢 こちらは CogniAIMZ の開発ログ・資料室です
        </h3>
        <p class="font-sans" style="font-size: 0.85rem; color: var(--color-navy); line-height: 1.5;">
            トレーニングツールの実行やサークル公式サイトのトップページは、以下よりアクセスしてください。<br>
            <a href="https://cogniaimz.chikyu.in/" target="_blank" rel="noopener noreferrer" style="color: var(--color-cyan); font-weight: bold; text-decoration: underline; font-size: 0.95rem; display: inline-block; margin-top: 8px;">
                CogniAIMZ 公式サイトへ戻る (cogniaimz.chikyu.in) ➔
            </a>
        </p>
    </div>

    <!-- コンテンツのグリッド表示 -->
    <div class="info-columns" style="grid-template-columns: 1fr 1fr; gap: 30px;">
        <!-- 左カラム：開発ログ & 参戦記 -->
        <div style="display: flex; flex-direction: column; gap: 30px;">
            <!-- 開発ログ -->
            <section class="devlog-section" id="devlog">
                <h2 class="section-title-cyber">Research & Devlog</h2>
                <div class="blog-list" style="margin-bottom: 15px;">
                    {sortedDevlogs.slice(0, 3).map((post) => (
                        <a href={`${import.meta.env.BASE_URL}/devlog/${post.id}/`} class="blog-item">
                            <div class="blog-meta">
                                <span class="blog-date font-mono">{formatDate(post.data.pubDate)}</span>
                                <span class="blog-tag font-mono">#{post.data.tag}</span>
                            </div>
                            <h3 class="blog-title">{post.data.title}</h3>
                        </a>
                    ))}
                    {sortedDevlogs.length === 0 && <p style="color: var(--text-muted); font-size: 0.8rem; padding: 10px;">記事がありません。</p>}
                </div>
                <div style="display: flex; justify-content: flex-end;">
                    <a href={`${import.meta.env.BASE_URL}/devlog/`} class="product-action-btn font-mono" style="text-decoration: none; padding: 4px 12px;">
                        VIEW ALL DEVLOGS ➔
                    </a>
                </div>
            </section>

            <!-- 参戦記 -->
            <section class="devlog-section" id="race">
                <h2 class="section-title-cyber">Motorsports Race Logs</h2>
                <div class="blog-list" style="margin-bottom: 15px;">
                    {sortedRaces.slice(0, 3).map((post) => (
                        <a href={`${import.meta.env.BASE_URL}/race/${post.id}/`} class="blog-item">
                            <div class="blog-meta">
                                <span class="blog-date font-mono">{formatDate(post.data.pubDate)}</span>
                                <span class="blog-tag font-mono" style="color: var(--color-cyan);">#Race</span>
                            </div>
                            <h3 class="blog-title">{post.data.title}</h3>
                        </a>
                    ))}
                    {sortedRaces.length === 0 && <p style="color: var(--text-muted); font-size: 0.8rem; padding: 10px;">参戦記録がありません。</p>}
                </div>
                <div style="display: flex; justify-content: flex-end;">
                    <a href={`${import.meta.env.BASE_URL}/race/`} class="product-action-btn font-mono" style="text-decoration: none; padding: 4px 12px;">
                        VIEW ALL RACE LOGS ➔
                    </a>
                </div>
            </section>
        </div>

        <!-- 右カラム：同人誌ログ & 出展イベント -->
        <div style="display: flex; flex-direction: column; gap: 30px;">
            <!-- 出展情報 -->
            <section class="event-section" id="event">
                <h2 class="section-title-cyber">Next Mission</h2>
                <div class="event-box" style="margin-bottom: 0;">
                    <div class="event-details">
                        <div class="event-header">
                            <h3 class="event-name">（近い将来の）技術書典 XX</h3>
                            <span class="event-date font-mono">2026.XX.XX</span>
                        </div>
                        <div class="event-info-row">
                            <span class="event-label font-sans">サークル名:</span>
                            <span class="event-value">CogniAIMZ (コグニエイムズ)</span>
                        </div>
                        <div class="event-info-row">
                            <span class="event-label font-sans">配置スペース:</span>
                            <span class="event-value highlight font-mono">ζ-FFb</span>
                        </div>
                        <div class="event-info-row">
                            <span class="event-label font-sans">頒布書籍:</span>
                            <span class="event-value">アマチュアレーサーにおける…</span>
                        </div>
                        <div class="event-info-row" style="margin-top: 15px;">
                            <span class="event-label font-sans" style="font-size: 0.8rem; line-height: 1.5; color: var(--text-muted);">
                                ※詳細なブース位置や委託・通販(BOOTH)リンクは決定次第、本エリアおよび公式SNSにて順次お知らせいたします。
                            </span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 出版書籍 -->
            <section class="event-section">
                <h2 class="section-title-cyber">Published Books</h2>
                <div class="blog-list" style="margin-bottom: 15px;">
                    {sortedBooks.slice(0, 3).map((post) => (
                        <a href={`${import.meta.env.BASE_URL}/books/${post.id}/`} class="blog-item">
                            <div class="blog-meta">
                                <span class="blog-date font-mono">{formatDate(post.data.pubDate)}</span>
                                <span class="blog-tag font-mono" style="color: var(--color-pink);">#Book</span>
                            </div>
                            <h3 class="blog-title">{post.data.title}</h3>
                        </a>
                    ))}
                    {sortedBooks.length === 0 && <p style="color: var(--text-muted); font-size: 0.8rem; padding: 10px;">本が登録されていません。</p>}
                </div>
                <div style="display: flex; justify-content: flex-end;">
                    <a href={`${import.meta.env.BASE_URL}/books/`} class="product-action-btn font-mono" style="text-decoration: none; padding: 4px 12px;">
                        VIEW ALL BOOKS ➔
                    </a>
                </div>
            </section>
        </div>
    </div>
</Layout>
